  // APP-01: amendを用いた名詞の単数・複数形修正
  {
    "instruction": "A sentence currently says that one apple is on the table, but it should describe three apples instead. Use amend to fix the noun phrase.",
    "dsl_program": "There is 1 apple on the table.\n[CODE]amend 1 apple -> 3 apples",
    "output_json": {
      "__STATEMENT__": "There are 3 apples on the table."
    }
  },
  {
    "instruction": "A sentence currently says there are two boxes, but it should describe one box instead. Use amend to correct both the quantity and the singular noun.",
    "dsl_program": "There are 2 boxes in the warehouse.\n[CODE]amend 2 boxes -> 1 box",
    "output_json": {
      "__STATEMENT__": "There is 1 box in the warehouse."
    }
  },
  {
    "instruction": "A sentence currently uses the third-person singular verb 'plays', but the subject is plural. Use amend to correct the verb.",
    "dsl_program": "The children plays soccer after school.\n[CODE]amend plays -> play",
    "output_json": {
      "__STATEMENT__": "The children play soccer after school."
    }
  },
  {
    "instruction": "A sentence currently refers to a single child, but it should refer to two children. Use amend to update the noun phrase.",
    "dsl_program": "I saw a child in the park.\n[CODE]amend a child -> two children",
    "output_json": {
      "__STATEMENT__": "I saw two children in the park."
    }
  },
  {
    "instruction": "A sentence currently refers to one book using 'this book', but it should refer to multiple books. Use amend to correct the demonstrative and plural noun.",
    "dsl_program": "Please read this book before class.\n[CODE]amend this book -> these books",
    "output_json": {
      "__STATEMENT__": "Please read these books before class."
    }
  },

  // APP-02: amendを用いた変数値の部分置換（変数スコープ）
  {
    "instruction": "A user's address has changed from Minato-ku to Shibuya-ku. Store the address in a variable, amend only the variable value, and then generate a sentence.",
    "dsl_program": "[CODE]$address = str \"Tokyo, Minato-ku\"\n[CODE]amend $address: Minato-ku -> Shibuya-ku\nThe user's address is $address.",
    "output_json": {
      "address": "Tokyo, Shibuya-ku",
      "__STATEMENT__": "The user's address is Tokyo, Shibuya-ku."
    }
  },
  {
    "instruction": "A task status currently says 'step 1: pending'. Amend only the variable so that it becomes 'step 1: completed', then report the status.",
    "dsl_program": "[CODE]$status = str \"step 1: pending\"\n[CODE]amend $status: pending -> completed\nCurrent status: $status.",
    "output_json": {
      "status": "step 1: completed",
      "__STATEMENT__": "Current status: step 1: completed."
    }
  },
  {
    "instruction": "A product name should be updated from 'iPhone 15 Pro' to 'iPhone 15 Pro Max'. Modify only the variable using amend and then describe the product.",
    "dsl_program": "[CODE]$product = str \"iPhone 15 Pro\"\n[CODE]amend $product: iPhone 15 Pro -> iPhone 15 Pro Max\nSelected product: $product.",
    "output_json": {
      "product": "iPhone 15 Pro Max",
      "__STATEMENT__": "Selected product: iPhone 15 Pro Max."
    }
  },
  {
    "instruction": "A software version currently contains 'v1.0.0-beta'. Amend only the variable so that it becomes 'v1.0.0-rc1', then display it.",
    "dsl_program": "[CODE]$version = str \"v1.0.0-beta\"\n[CODE]amend $version: beta -> rc1\nSoftware version: $version.",
    "output_json": {
      "version": "v1.0.0-rc1",
      "__STATEMENT__": "Software version: v1.0.0-rc1."
    }
  },
  {
    "instruction": "A filename currently ends with the '.txt' extension. Amend only the variable so that it becomes a PDF file, then generate a sentence.",
    "dsl_program": "[CODE]$filename = str \"report.txt\"\n[CODE]amend $filename: .txt -> .pdf\nOutput file: $filename.",
    "output_json": {
      "filename": "report.pdf",
      "__STATEMENT__": "Output file: report.pdf."
    }
  },

  // APP-03: amend $STATEMENTによるテキストの部分修正
  {
    "instruction": "Generate a sentence stating that a meeting is on Monday. Afterwards, correct the weekday to Tuesday by amending the generated statement.",
    "dsl_program": "The meeting is scheduled for Monday.\n[CODE]amend $STATEMENT: Monday -> Tuesday",
    "output_json": {
      "__STATEMENT__": "The meeting is scheduled for Tuesday."
    }
  },
  {
    "instruction": "Generate a sentence containing the misspelled word 'recieved'. Correct the typo by amending the generated statement.",
    "dsl_program": "Your package has been recieved successfully.\n[CODE]amend $STATEMENT: recieved -> received",
    "output_json": {
      "__STATEMENT__": "Your package has been received successfully."
    }
  },
  {
    "instruction": "Generate a Japanese sentence using the casual expression 'あげる'. Then upgrade it to the more polite expression '差し上げる' by amending the generated statement.",
    "dsl_program": "私は先生にこの本をあげます。\n[CODE]amend $STATEMENT: あげます -> 差し上げます",
    "output_json": {
      "__STATEMENT__": "私は先生にこの本を差し上げます。"
    }
  },
  {
    "instruction": "Generate a sentence containing an email address. Then anonymize the email address by amending the generated statement.",
    "dsl_program": "My email is secret@example.com.\n[CODE]amend $STATEMENT: secret@example.com -> [REDACTED]",
    "output_json": {
      "__STATEMENT__": "My email is [REDACTED]."
    }
  },
  {
    "instruction": "Generate a sentence saying that Alice went to school. Then replace the person's name with Bob by amending the generated statement.",
    "dsl_program": "Alice went to school.\n[CODE]amend $STATEMENT: Alice -> Bob",
    "output_json": {
      "__STATEMENT__": "Bob went to school."
    }
  },

  // APP-04: dict型データの作成と要素へのアクセス
  {
    "instruction": "Create a dictionary representing a user profile with the fields name, age, and country. Access each field using dot notation, verify the values with show, and generate a summary sentence.",
    "dsl_program": "[CODE]$profile = dict name:str \"Alice\", age:int 30, country:str \"Canada\"\n[CODE]show $profile.name\n[RESULT]Alice\n[CODE]show $profile.age\n[RESULT]30\n[CODE]show $profile.country\n[RESULT]Canada\nUser $profile.name is $profile.age years old and lives in $profile.country.",
    "output_json": {
      "profile": {
        "name": "Alice",
        "age": 30,
        "country": "Canada"
      },
      "__STATEMENT__": "User Alice is 30 years old and lives in Canada."
    }
  },
  {
    "instruction": "Create a dictionary representing a product specification with the fields brand, model, and price. Access each field using dot notation and describe the product.",
    "dsl_program": "[CODE]$product = dict brand:str \"OpenAI\", model:str \"Model X\", price:float 199.99\n[CODE]show $product.brand\n[RESULT]OpenAI\n[CODE]show $product.model\n[RESULT]Model X\n[CODE]show $product.price\n[RESULT]199.99\nThe product is $product.brand $product.model and costs $product.price dollars.",
    "output_json": {
      "product": {
        "brand": "OpenAI",
        "model": "Model X",
        "price": 199.99
      },
      "__STATEMENT__": "The product is OpenAI Model X and costs 199.99 dollars."
    }
  },
  {
    "instruction": "Create a dictionary representing weather information with the fields temp, humidity, and wind. Access the values using dot notation and report the weather.",
    "dsl_program": "[CODE]$weather = dict temp:float 25.4, humidity:int 60, wind:str \"North\"\n[CODE]show $weather.temp\n[RESULT]25.4\n[CODE]show $weather.humidity\n[RESULT]60\n[CODE]show $weather.wind\n[RESULT]North\nThe temperature is $weather.temp degrees, humidity is $weather.humidity%, and the wind is from the $weather.wind.",
    "output_json": {
      "weather": {
        "temp": 25.4,
        "humidity": 60,
        "wind": "North"
      },
      "__STATEMENT__": "The temperature is 25.4 degrees, humidity is 60%, and the wind is from the North."
    }
  },
  {
    "instruction": "Create a dictionary representing a server status with the fields host, ip, and active. Access each field using dot notation, verify them with show, and summarize the server state.",
    "dsl_program": "[CODE]$server = dict host:str \"server01\", ip:str \"192.168.1.10\", active:bool true\n[CODE]show $server.host\n[RESULT]server01\n[CODE]show $server.ip\n[RESULT]192.168.1.10\n[CODE]show $server.active\n[RESULT]true\nServer $server.host ($server.ip) is active: $server.active.",
    "output_json": {
      "server": {
        "host": "server01",
        "ip": "192.168.1.10",
        "active": true
      },
      "__STATEMENT__": "Server server01 (192.168.1.10) is active: true."
    }
  },
  {
    "instruction": "Create a dictionary representing a book with the fields title, author, and year. Access each field using dot notation and generate a short description.",
    "dsl_program": "[CODE]$book = dict title:str \"The DSL Guide\", author:str \"Jane Smith\", year:int 2026\n[CODE]show $book.title\n[RESULT]The DSL Guide\n[CODE]show $book.author\n[RESULT]Jane Smith\n[CODE]show $book.year\n[RESULT]2026\n\"$book.title\" was written by $book.author in $book.year.",
    "output_json": {
      "book": {
        "title": "The DSL Guide",
        "author": "Jane Smith",
        "year": 2026
      },
