// xxgemma_sft_dataset.jsonc
// Version 0.0.1 (Time-stamp: <2026-07-08T18:26:59Z>)
//
// xxLLM (JSON を出力する xLLM に対し、JSON を出力するプログラムを出力
// する LLM) を Gemma のファインチューニングで実装する。そのプロジェク
// トを xxGemma と呼ぶ。このデータセットはそのファインチューニング用の
// データセットである。
//
// このデータセットは私が定義した DSL 仕様をもとに、Gemini 3.5 Flash
// さんに列挙してもらったシチュエーションを ChatGPT 5.5(?) さんに DSL
// プログラムにしてもらったもの。
//
// シチュエーションは大項目が 66 あり、それぞれに 5 例ずつ具体的な例が
// ある。
//
// なお、output_json は SFT に用いることはないため、チェックしていない。
// あくまで ChatGPT さんによる予想で、正しくない可能性が結構あるが、イ
// ンタプリタに実装されてない要素も学習だけはさせることがあるため、そ
// のままにした。
//
// Author: JRF ( https://github.com/JRF-2018 )
//
// License:
//
// 私自身は Public Domain にしたいのですが、それだと逆に扱いにくいとい
// う場合、AI 作成に問題を関じる場合などは、MIT License でお願いします。

[
  // 1. 正常系（基本）：20シチュエーション (BASE-01 〜 BASE-20)
  
  // BASE-01: 名前の代入と自己紹介文の出力
  {
    "instruction": "Introduce yourself in English using the name Alice.",
    "dsl_program": "[CODE]$name = str \"Alice\"\nMy name is $name.",
    "output_json": {
      "__STATEMENT__": "My name is Alice.",
      "name": "Alice"
    }
  },
  {
    "instruction": "「太郎」という名前で日本語の自己紹介をしてください。",
    "dsl_program": "[CODE]$name = str \"太郎\"\n私は$nameです。",
    "output_json": {
      "__STATEMENT__": "私は太郎です。",
      "name": "太郎"
    }
  },
  {
    "instruction": "Introduce yourself politely using the name Mr. Smith.",
    "dsl_program": "[CODE]$name = str \"Mr. Smith\"\n[CODE]show $name\n[RESULT]Mr. Smith\nMy name is $RESULT.",
    "output_json": {
      "__STATEMENT__": "My name is Mr. Smith.",
      "name": "Mr. Smith"
    }
  },
  {
    "instruction": "Introduce yourself as Bob the builder.",
    "dsl_program": "[CODE]$name = str \"Bob\"\n[CODE]$job = str \"builder\"\nI am $name the $job.",
    "output_json": {
      "__STATEMENT__": "I am Bob the builder.",
      "name": "Bob",
      "job": "builder"
    }
  },
  {
    "instruction": "Introduce yourself using the nickname Charlie.",
    "dsl_program": "[CODE]$nickname = str \"Charlie\"\n[CODE]show $nickname\n[RESULT]Charlie\nMy nickname is $RESULT.",
    "output_json": {
      "__STATEMENT__": "My nickname is Charlie.",
      "nickname": "Charlie"
    }
  },

  // BASE-02: 数量の代入と基本カウント
  {
    "instruction": "Store the number of apples in an integer variable and generate a sentence describing the quantity.",
    "dsl_program": "[CODE]$count = int 3\nThere are $count apples on the table.",
    "output_json": {
      "__STATEMENT__": "There are 3 apples on the table.",
      "count": 3
    }
  },
  {
    "instruction": "本の冊数を整数変数に代入し、その冊数を含む日本語の文章を生成してください。",
    "dsl_program": "[CODE]$books = int 5\n[CODE]show $books\n[RESULT]5\n私は$RESULT冊の本を持っています。",
    "output_json": {
      "__STATEMENT__": "私は5冊の本を持っています。",
      "books": 5
    }
  },
  {
    "instruction": "Store the number of dogs in an integer variable and report it in English.",
    "dsl_program": "[CODE]$dogs = int 10\nThe farm has $dogs dogs.\n[CODE]show $dogs\n[RESULT]10",
    "output_json": {
      "__STATEMENT__": "The farm has 10 dogs.",
      "dogs": 10
    }
  },
  {
    "instruction": "Store the number of cups in an integer variable and generate a sentence using the singular form.",
    "dsl_program": "[CODE]$cups = int 1\nThere is $cups cup on the desk.",
    "output_json": {
      "__STATEMENT__": "There is 1 cup on the desk.",
      "cups": 1
    }
  },
  {
    "instruction": "ペンの本数を整数変数に代入し、日本語で数量を報告してください。",
    "dsl_program": "[CODE]$pens = int 12\n文房具箱には$pens本のペンがあります。\n[CODE]show $pens\n[RESULT]12",
    "output_json": {
      "__STATEMENT__": "文房具箱には12本のペンがあります。",
      "pens": 12
    }
  },

  // BASE-03: 価格の計算と合計値の表示
  {
    "instruction": "Calculate the total price of three items that each cost 10 dollars.",
    "dsl_program": "[CODE]$unit_price = int 10\n[CODE]$quantity = int 3\n[CODE]show $unit_price * $quantity\n[RESULT]30\nThe total price is $$RESULT.",
    "output_json": {
      "__STATEMENT__": "The total price is $30.",
      "unit_price": 10,
      "quantity": 3,
      "total_price": 30
    }
  },
  {
    "instruction": "Calculate the total cost of two pens priced at 1.50 dollars each.",
    "dsl_program": "[CODE]$unit_price = float 1.5\n[CODE]$quantity = int 2\n[CODE]show $unit_price * $quantity\n[RESULT]3.0\nThe total price of the pens is $$RESULT.",
    "output_json": {
      "__STATEMENT__": "The total price of the pens is $3.0.",
      "unit_price": 1.5,
      "quantity": 2,
      "total_price": 3.0
    }
  },
  {
    "instruction": "Calculate the total cost of five sale items priced at 9.99 dollars each.",
    "dsl_program": "[CODE]$unit_price = float 9.99\n[CODE]$quantity = int 5\n[CODE]show $unit_price * $quantity\n[RESULT]49.95\nThe total cost of the sale items is $$RESULT.",
    "output_json": {
      "__STATEMENT__": "The total cost of the sale items is $49.95.",
      "unit_price": 9.99,
      "quantity": 5,
      "total_price": 49.95
    }
  },
  {
    "instruction": "120円の缶コーヒーを4本買った合計金額を計算してください。",
    "dsl_program": "[CODE]$unit_price = int 120\n[CODE]$quantity = int 4\n[CODE]show $unit_price * $quantity\n[RESULT]480\n合計金額は$RESULT円です。",
    "output_json": {
      "__STATEMENT__": "合計金額は480円です。",
      "unit_price": 120,
      "quantity": 4,
      "total_price": 480
    }
  },
  {
    "instruction": "Calculate the total price of five free items.",
    "dsl_program": "[CODE]$unit_price = int 0\n[CODE]$quantity = int 5\n[CODE]show $unit_price * $quantity\n[RESULT]0\nThe total price is $$RESULT.",
    "output_json": {
      "__STATEMENT__": "The total price is $0.",
      "unit_price": 0,
      "quantity": 5,
      "total_price": 0
    }
  },

  // BASE-04: 身長と体重（float型）の記録と表示
  {
    "instruction": "Record a person's height as a floating-point value and generate a sentence.",
    "dsl_program": "[CODE]$height = float 175.5\n[CODE]show $height\n[RESULT]175.5\nThe person's height is $RESULT cm.",
    "output_json": {
      "__STATEMENT__": "The person's height is 175.5 cm.",
      "height": 175.5
    }
  },
  {
    "instruction": "Record a person's weight as a floating-point value and report it.",
    "dsl_program": "[CODE]$weight = float 68.2\nThe person's weight is $weight kg.",
    "output_json": {
      "__STATEMENT__": "The person's weight is 68.2 kg.",
      "weight": 68.2
    }
  },
  {
    "instruction": "赤ちゃんの体重を浮動小数点数で記録し、日本語で文章を作成してください。",
    "dsl_program": "[CODE]$weight = float 3.15\n[CODE]show $weight\n[RESULT]3.15\n赤ちゃんの体重は$RESULT kgです。",
    "output_json": {
      "__STATEMENT__": "赤ちゃんの体重は3.15 kgです。",
      "weight": 3.15
    }
  },
  {
    "instruction": "Record a sprinter's 100-meter race time as a floating-point value.",
    "dsl_program": "[CODE]$time = float 9.58\n[CODE]show $time\n[RESULT]9.58\nThe athlete finished the 100-meter race in $RESULT seconds.",
    "output_json": {
      "__STATEMENT__": "The athlete finished the 100-meter race in 9.58 seconds.",
      "time": 9.58
    }
  },
  {
    "instruction": "気温を浮動小数点数で記録し、日本語で報告してください。",
    "dsl_program": "[CODE]$temperature = float 25.4\n今日の気温は$temperature度です。",
    "output_json": {
      "__STATEMENT__": "今日の気温は25.4度です。",
      "temperature": 25.4
    }
  },

  // BASE-05: 三角関数を用いた単純な計算
  {
    "instruction": "Calculate a value using cos(0) and include the result in a sentence.",
    "dsl_program": "[CODE]$value = int 1 + cos(0)\n[CODE]show $value\n[RESULT]2\nThe calculated value is $RESULT.",
    "output_json": {
      "__STATEMENT__": "The calculated value is 2.",
      "value": 2
    }
  },
  {
    "instruction": "Calculate a value using sin(0) and report the result.",
    "dsl_program": "[CODE]$value = int 5 + sin(0)\n[CODE]show $value\n[RESULT]5\nThe calculated value is $RESULT.",
    "output_json": {
      "__STATEMENT__": "The calculated value is 5.",
      "value": 5
    }
  },
  {
    "instruction": "Convert 90 degrees to radians and calculate its sine.",
    "dsl_program": "[CODE]$degree = int 90\n[CODE]$radian = float $degree * 3.141592653589793 / 180\n[CODE]show sin($radian)\n[RESULT]1.0\nThe sine of 90 degrees is $RESULT.",
    "output_json": {
      "__STATEMENT__": "The sine of 90 degrees is 1.0.",
      "degree": 90,
      "radian": 1.5707963267948966
    }
  },
  {
    "instruction": "Multiply the result of cos(0) by a constant and display it.",
    "dsl_program": "[CODE]show cos(0) * 10\n[RESULT]10\n[CODE]$score = int $RESULT\nThe score is $score.",
    "output_json": {
      "__STATEMENT__": "The score is 10.",
      "score": 10
    }
  },
  {
    "instruction": "Calculate the sum of sin(0) and cos(0), then report the result.",
    "dsl_program": "[CODE]show sin(0) + cos(0)\n[RESULT]1.0\n[CODE]$value = float $RESULT\nThe combined value is $value.",
    "output_json": {
      "__STATEMENT__": "The combined value is 1.0.",
      "value": 1.0
    }
  },

  // BASE-06: 複数の変数の結合（文字列結合）
  {
    "instruction": "Store a first name and a last name separately, then generate a sentence containing the full name.",
    "dsl_program": "[CODE]$first_name = str \"John\"\n[CODE]$last_name = str \"Doe\"\nMy name is $first_name $last_name.\n[CODE]show $first_name\n[RESULT]\"John\"",
    "output_json": {
      "__STATEMENT__": "My name is John Doe.",
      "first_name": "John",
      "last_name": "Doe"
    }
  },
  {
    "instruction": "姓と名を別々の文字列変数に代入し、日本語の自己紹介文を生成してください。",
    "dsl_program": "[CODE]$last_name = str \"山田\"\n[CODE]$first_name = str \"太郎\"\n私は$last_name$first_nameです。",
    "output_json": {
      "__STATEMENT__": "私は山田太郎です。",
      "last_name": "山田",
      "first_name": "太郎"
    }
  },
  {
    "instruction": "Store a first name, middle name, and last name, then introduce the person using the complete name.",
    "dsl_program": "[CODE]$first_name = str \"John\"\n[CODE]$middle_name = str \"Fitzgerald\"\n[CODE]$last_name = str \"Kennedy\"\n[CODE]show $middle_name\n[RESULT]\"Fitzgerald\"\nThe full name is $first_name $RESULT $last_name.",
    "output_json": {
      "__STATEMENT__": "The full name is John Fitzgerald Kennedy.",
      "first_name": "John",
      "middle_name": "Fitzgerald",
      "last_name": "Kennedy"
    }
  },
  {
    "instruction": "Store an honorific title and a family name separately, then generate a formal introduction.",
    "dsl_program": "[CODE]$title = str \"Dr.\"\n[CODE]$name = str \"House\"\nPlease welcome $title $name.",
    "output_json": {
      "__STATEMENT__": "Please welcome Dr. House.",
      "title": "Dr.",
      "name": "House"
    }
  },
  {
    "instruction": "Store a user ID prefix and a numeric identifier as strings, then generate a user account name.",
    "dsl_program": "[CODE]$prefix = str \"User\"\n[CODE]$id = str \"1024\"\n[CODE]show $id\n[RESULT]\"1024\"\nThe account name is $prefix$RESULT.",
    "output_json": {
      "__STATEMENT__": "The account name is User1024.",
      "prefix": "User",
      "id": "1024"
    }
  },
  
  // BASE-07: 単純な加減算と文脈出力
  {
    "instruction": "Calculate the number of apples after receiving two more apples.",
    "dsl_program": "[CODE]$initial = int 3\n[CODE]$received = int 2\n[CODE]show $initial + $received\n[RESULT]5\n[CODE]$apples = int $RESULT\nI have $apples apples now.",
    "output_json": {
      "__STATEMENT__": "I have 5 apples now.",
      "initial": 3,
      "received": 2,
      "apples": 5
    }
  },
  {
    "instruction": "30円支払った後の残金を計算してください。",
    "dsl_program": "[CODE]$money = int 100\n[CODE]$payment = int 30\n[CODE]show $money - $payment\n[RESULT]70\n[CODE]$remaining = int $RESULT\n支払い後の残金は$remaining円です。",
    "output_json": {
      "__STATEMENT__": "支払い後の残金は70円です。",
      "money": 100,
      "payment": 30,
      "remaining": 70
    }
  },
  {
    "instruction": "Calculate the total number of guests after one additional guest arrives.",
    "dsl_program": "[CODE]$guests = int 5\n[CODE]$new_guest = int 1\n[CODE]show $guests + $new_guest\n[RESULT]6\nThere are $RESULT guests at the party.",
    "output_json": {
      "__STATEMENT__": "There are 6 guests at the party.",
      "guests": 5,
      "new_guest": 1,
      "total_guests": 6
    }
  },
  {
    "instruction": "Calculate the remaining number of tickets after using two tickets.",
    "dsl_program": "[CODE]$tickets = int 10\n[CODE]$used = int 2\n[CODE]show $tickets - $used\n[RESULT]8\n[CODE]$remaining = int $RESULT\nThere are $remaining tickets left.",
    "output_json": {
      "__STATEMENT__": "There are 8 tickets left.",
      "tickets": 10,
      "used": 2,
      "remaining": 8
    }
  },
  {
    "instruction": "往復の移動距離を計算してください。",
    "dsl_program": "[CODE]$outbound = int 5\n[CODE]$return = int 5\n[CODE]show $outbound + $return\n[RESULT]10\n往復の移動距離は$RESULT kmです。",
    "output_json": {
      "__STATEMENT__": "往復の移動距離は10 kmです。",
      "outbound": 5,
      "return": 5,
      "total_distance": 10
    }
  },

  // BASE-08: 割り算と余りの基本計算
  {
    "instruction": "Divide 10 cookies equally between 2 people and report how many cookies each person receives.",
    "dsl_program": "[CODE]$cookies = int 10\n[CODE]$people = int 2\n[CODE]show $cookies / $people\n[RESULT]5\nEach person receives $RESULT cookies.",
    "output_json": {
      "__STATEMENT__": "Each person receives 5 cookies.",
      "cookies": 10,
      "people": 2,
      "each": 5
    }
  },
  {
    "instruction": "Divide 10 candies among 3 people and report both the quotient and the remainder.",
    "dsl_program": "[CODE]$candies = int 10\n[CODE]$people = int 3\n[CODE]show $candies / $people\n[RESULT]3\n[CODE]$each = int $RESULT\n[CODE]show $candies % $people\n[RESULT]1\nEach person receives $each candies, with $RESULT candy remaining.",
    "output_json": {
      "__STATEMENT__": "Each person receives 3 candies, with 1 candy remaining.",
      "candies": 10,
      "people": 3,
      "each": 3,
      "remainder": 1
    }
  },
  {
    "instruction": "Divide 100 dollars equally among 4 people and report the amount each person receives.",
    "dsl_program": "[CODE]$money = int 100\n[CODE]$people = int 4\n[CODE]show $money / $people\n[RESULT]25\nEach person receives \\$$RESULT.",
    "output_json": {
      "__STATEMENT__": "Each person receives $25.",
      "money": 100,
      "people": 4,
      "each": 25
    }
  },
  {
    "instruction": "1週間7日を2つの期間に均等に分けたときの日数と余りを計算してください。",
    "dsl_program": "[CODE]$days = int 7\n[CODE]$periods = int 2\n[CODE]show $days / $periods\n[RESULT]3\n[CODE]$each = int $RESULT\n[CODE]show $days % $periods\n[RESULT]1\n1期間あたり$each日で、余りは$RESULT日です。",
    "output_json": {
      "__STATEMENT__": "1期間あたり3日で、余りは1日です。",
      "days": 7,
      "periods": 2,
      "each": 3,
      "remainder": 1
    }
  },
  {
    "instruction": "Distribute 50 playing cards equally among 7 people and report both the number of cards each person receives and the remainder.",
    "dsl_program": "[CODE]$cards = int 50\n[CODE]$people = int 7\n[CODE]show $cards / $people\n[RESULT]7\n[CODE]$each = int $RESULT\n[CODE]show $cards % $people\n[RESULT]1\nThere are $each cards for each person, with $RESULT card left over.",
    "output_json": {
      "__STATEMENT__": "There are 7 cards for each person, with 1 card left over.",
      "cards": 50,
      "people": 7,
      "each": 7,
      "remainder": 1
    }
  },

  // BASE-09: バックスラッシュを用いた特殊記号のエスケープ
  {
    "instruction": "Generate a sentence that uses escaped parentheses for singular and plural notation.",
    "dsl_program": "[CODE]$count = int 2\n[CODE]show $count\n[RESULT]2\nThe child has $RESULT ball\\(s\\).",
    "output_json": {
      "__STATEMENT__": "The child has 2 ball(s).",
      "count": 2
    }
  },
  {
    "instruction": "Generate a sentence containing an escaped dollar sign.",
    "dsl_program": "[CODE]$price = int 100\nThe price is \\$$price.",
    "output_json": {
      "__STATEMENT__": "The price is $100.",
      "price": 100
    }
  },
  {
    "instruction": "括弧付きの補足説明を含む文章を生成してください。",
    "dsl_program": "[CODE]$option = str \"Optional\"\nThis feature is \\($option\\).",
    "output_json": {
      "__STATEMENT__": "This feature is (Optional).",
      "option": "Optional"
    }
  },
  {
    "instruction": "Generate a sentence that contains a literal backslash character.",
    "dsl_program": "[CODE]$path = str \"folder\\\\file.txt\"\n[CODE]show $path\n[RESULT]folder\\file.txt\nThe file path is $path.",
    "output_json": {
      "__STATEMENT__": "The file path is folder\\file.txt.",
      "path": "folder\\file.txt"
    }
  },
  {
    "instruction": "Generate a sentence that contains a programming variable name beginning with a dollar sign.",
    "dsl_program": "The variable name is \\$x.\n[CODE]$description = str \"example variable\"",
    "output_json": {
      "__STATEMENT__": "The variable name is $x.",
      "description": "example variable"
    }
  },

  // BASE-10: 変数の再代入によるシンプルな上書き
  {
    "instruction": "Update a player's score from 0 to 10 and report the final score.",
    "dsl_program": "[CODE]$score = int 0\n[CODE]$score = int 10\n[CODE]show $score\n[RESULT]10\nThe final score is $RESULT.",
    "output_json": {
      "__STATEMENT__": "The final score is 10.",
      "score": 10
    }
  },
  {
    "instruction": "Update the weather from sunny to rainy and generate a weather report.",
    "dsl_program": "[CODE]$weather = str \"sunny\"\n[CODE]$weather = str \"rainy\"\nToday's weather is $weather.",
    "output_json": {
      "__STATEMENT__": "Today's weather is rainy.",
      "weather": "rainy"
    }
  },
  {
    "instruction": "Change a task status from idle to busy and report the current status.",
    "dsl_program": "[CODE]$status = str \"idle\"\n[CODE]$status = str \"busy\"\n[CODE]show $status\n[RESULT]busy\nThe current status is $RESULT.",
    "output_json": {
      "__STATEMENT__": "The current status is busy.",
      "status": "busy"
    }
  },
  {
    "instruction": "目的地をTokyoからOsakaへ変更し、現在の目的地を報告してください。",
    "dsl_program": "[CODE]$destination = str \"Tokyo\"\n[CODE]$destination = str \"Osaka\"\n現在の目的地は$destinationです。",
    "output_json": {
      "__STATEMENT__": "現在の目的地はOsakaです。",
      "destination": "Osaka"
    }
  },
  {
    "instruction": "Update the movement speed from slow to fast and report the final speed.",
    "dsl_program": "[CODE]$speed = str \"slow\"\n[CODE]$speed = str \"fast\"\n[CODE]show $speed\n[RESULT]fast\nThe robot is moving at $RESULT speed.",
    "output_json": {
      "__STATEMENT__": "The robot is moving at fast speed.",
      "speed": "fast"
    }
  },

  // BASE-11: 複数アイテム of カウントとリスト作成の準備
  {
    "instruction": "Store the numbers of red balls and blue balls separately, then report both quantities.",
    "dsl_program": "[CODE]$red_balls = int 4\n[CODE]$blue_balls = int 7\nThere are $red_balls red balls and $blue_balls blue balls.",
    "output_json": {
      "__STATEMENT__": "There are 4 red balls and 7 blue balls.",
      "red_balls": 4,
      "blue_balls": 7
    }
  },
  {
    "instruction": "Store the numbers of cups of coffee and cups of tea, then generate a sentence.",
    "dsl_program": "[CODE]$coffee = int 3\n[CODE]$tea = int 5\n[CODE]show $coffee\n[RESULT]3\nThere are $RESULT cups of coffee and $tea cups of tea.",
    "output_json": {
      "__STATEMENT__": "There are 3 cups of coffee and 5 cups of tea.",
      "coffee": 3,
      "tea": 5
    }
  },
  {
    "instruction": "大人チケットと子供チケットの枚数を記録し、日本語で報告してください。",
    "dsl_program": "[CODE]$adult_tickets = int 8\n[CODE]$child_tickets = int 3\n大人チケットは$adult_tickets枚、子供チケットは$child_tickets枚です。",
    "output_json": {
      "__STATEMENT__": "大人チケットは8枚、子供チケットは3枚です。",
      "adult_tickets": 8,
      "child_tickets": 3
    }
  },
  {
    "instruction": "Record the numbers of successful and failed uploads, then generate a status report.",
    "dsl_program": "[CODE]$success = int 15\n[CODE]$failed = int 2\n[CODE]show $failed\n[RESULT]2\nUpload completed with $success successful uploads and $RESULT failed uploads.",
    "output_json": {
      "__STATEMENT__": "Upload completed with 15 successful uploads and 2 failed uploads.",
      "success": 15,
      "failed": 2
    }
  },
  {
    "instruction": "犬と猫の頭数を記録し、日本語で報告してください。",
