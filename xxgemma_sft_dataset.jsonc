    }
  },
  {
    "instruction": "Detect a condition that requires an empty result. Create an empty dictionary, verify it with show, and return it immediately.",
    "dsl_program": "[CODE]$result = dict\n[CODE]show $result\n[RESULT]{}\n[CODE]return $result",
    "output_json": {
      "result": {},
      "__RETURN__": {}
    }
  },
  {
    "instruction": "Prepare a static API configuration object. Review the endpoint with show and return the configuration without producing any further statement.",
    "dsl_program": "[CODE]$config = dict endpoint:str \"/api/v1/status\", timeout:int 30, retry:bool true\n[CODE]show $config.endpoint\n[RESULT]/api/v1/status\n[CODE]return $config",
