  // PHYS-07: アームの過負荷・関節の限界（Joint Limit/Overload）
  {
    "instruction": "A warehouse robot experienced a sudden battery voltage drop while transporting inventory.\n\nimport tensor\n  - tensor <expr>: convert data into a tensor.\n\nimport warehouse_carrier\n  - inspect_power_state() -> tensor : Observe the current power system.\n  - transport_inventory() -> None : Continue transporting inventory.\n  - estimate_remaining_range() -> dict : Estimate the remaining travel capability.\n  - divert_to_charger(location: str) -> None : Navigate toward a charging station.\n  - preserve_task() -> None : Save the current task for later resumption.\n\nRecover while avoiding a complete power loss.",
    "dsl_program": "[CODE]import tensor\n[CODE]import warehouse_carrier\n[CODE]$power = tensor inspect_power_state()\n[CODE]transport_inventory()\n[EXCEPTION]BatteryException: Battery voltage dropped faster than predicted.\n[COMMENT]Prevent mission failure by preserving the current task before rerouting.\n[CODE]show estimate_remaining_range()\n[RESULT]{\"station\":\"charger_b\",\"margin\":42}\n[CODE]$range = dict $RESULT\n[CODE]preserve_task()\n[CODE]divert_to_charger($range.station)",
    "output_json": {
      "power": {
	"__type__": "tensor",
	"__value__": null
      },
      "range": {
	"station": "charger_b",
	"margin": 42
      },
      "__STATEMENT__": ""
    }
  },
  {
    "instruction": "A drone detected an unexpected increase in power consumption during an inspection flight.\n\nimport tensor\n  - tensor <expr>: convert data into a tensor.\n\nimport drone_surveyor\n  - monitor_energy() -> tensor : Monitor onboard energy usage.\n  - inspect_powerline() -> None : Perform aerial inspection.\n  - analyze_power_drain() -> str : Determine the primary cause of energy loss.\n  - reduce_cruise_speed() -> None : Lower the cruise speed.\n  - return_to_base() -> None : Return to the launch site.\n\nRecover by maximizing the probability of a safe landing.",
    "dsl_program": "[CODE]import tensor\n[CODE]import drone_surveyor\n[CODE]$energy = tensor monitor_energy()\n[CODE]inspect_powerline()\n[EXCEPTION]BatteryException: Energy consumption exceeded the planned flight profile.\n[COMMENT]Mission completion is secondary to maintaining sufficient landing reserve.\n[CODE]show analyze_power_drain()\n[RESULT]\"strong_headwind\"\n[CODE]$cause = str $RESULT\n[CODE]reduce_cruise_speed()\n[CODE]return_to_base()",
    "output_json": {
      "energy": {
	"__type__": "tensor",
	"__value__": null
      },
      "cause": "strong_headwind",
      "__STATEMENT__": ""
    }
  },
  {
    "instruction": "巡回ロボットが充電ドック目前で残量不足を検知しました。\n\nimport tensor\n  - tensor <expr>: テンソルへ変換します。\n\nimport security_patrol\n  - observe_battery() -> tensor : バッテリー状態を取得\n  - patrol_zone() -> None : 巡回を実行\n  - estimate_reachable_docks() -> list : 到達可能な充電ドックを列挙\n  - select_destination(candidates: list) -> str : 最適な充電先を選択\n  - head_to_dock(name: str) -> None : 充電ドックへ向かう\n\n現在の任務を続行するより安全な充電を優先してください。",
    "dsl_program": "[CODE]import tensor\n[CODE]import security_patrol\n[CODE]$battery = tensor observe_battery()\n[CODE]patrol_zone()\n[EXCEPTION]BatteryException: Remaining capacity fell below the emergency threshold.\n[COMMENT]Choose the charging station that can be reached with the highest safety margin.\n[CODE]show estimate_reachable_docks()\n[RESULT][\"dock_a\",\"dock_c\"]\n[CODE]$docks = list $RESULT\n[CODE]show select_destination($docks)\n[RESULT]\"dock_c\"\n[CODE]head_to_dock(\"dock_c\")",
