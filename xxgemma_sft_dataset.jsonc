  {
    "instruction": "Calculate the final salary by adding an allowance to the base salary and then subtracting tax.",
    "dsl_program": "[CODE]$base_salary = int 3000\n[CODE]$allowance = int 500\n[CODE]$subtotal = int $base_salary + $allowance\n[CODE]$tax = int 400\n[CODE]$final_salary = int $subtotal - $tax\nThe final salary is $final_salary dollars.",
    "output_json": {
      "__STATEMENT__": "The final salary is 3100 dollars.",
      "base_salary": 3000,
      "allowance": 500,
      "tax": 400,
      "subtotal": 3500,
      "final_salary": 3100
    }
  },
  {
    "instruction": "Calculate the final selling price by adding profit to the cost and then applying a 10 percent tax.",
    "dsl_program": "[CODE]$cost = int 100\n[CODE]$profit = int 20\n[CODE]$subtotal = int $cost + $profit\n[CODE]$final_price = float $subtotal * 1.1\nThe final selling price is \\$$final_price.",
    "output_json": {
      "__STATEMENT__": "The final selling price is $132.0.",
      "cost": 100,
      "profit": 20,
      "subtotal": 120,
      "final_price": 132.0
    }
  },
