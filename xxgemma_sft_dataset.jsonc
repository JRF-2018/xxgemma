  },

  // APP-10: 複数のamendを連続して実行するパイプライン
  {
    "instruction": "Generate a meeting announcement containing a date, time, and location. Update them one by one using multiple amend operations.",
    "dsl_program": "The meeting will be held on July 1 at 10:00 in Room A.\n[CODE]amend $STATEMENT: July 1 -> July 8\n[CODE]amend $STATEMENT: 10:00 -> 14:00\n[CODE]amend $STATEMENT: Room A -> Room B",
    "output_json": {
      "__STATEMENT__": "The meeting will be held on July 8 at 14:00 in Room B."
    }
  },
  {
    "instruction": "Generate a sentence containing a typo, an inappropriate word, and a missing honorific. Correct the text step by step using multiple amend operations.",
    "dsl_program": "mr. smith recieved your file.\n[CODE]amend $STATEMENT: mr. -> Mr.\n[CODE]amend $STATEMENT: smith -> Smith\n[CODE]amend $STATEMENT: recieved -> received",
    "output_json": {
      "__STATEMENT__": "Mr. Smith received your file."
    }
  },
  {
    "instruction": "Generate a simple Markdown sentence and convert it into HTML step by step using multiple amend operations.",
    "dsl_program": "**Important** information.\n[CODE]amend $STATEMENT: ** -> <b>\n[CODE]amend $STATEMENT: ** -> </b>",
    "output_json": {
      "__STATEMENT__": "<b>Important</b> information."
    }
  },
  {
    "instruction": "Generate a sentence containing a password, a credit card number, and a phone number. Hide each sensitive item one at a time using multiple amend operations.",
    "dsl_program": "Password: secret123, Card: 4111-1111-1111-1111, Phone: 090-1234-5678.\n[CODE]amend $STATEMENT: secret123 -> ******\n[CODE]amend $STATEMENT: 4111-1111-1111-1111 -> [CARD REDACTED]\n[CODE]amend $STATEMENT: 090-1234-5678 -> [PHONE REDACTED]",
    "output_json": {
      "__STATEMENT__": "Password: ******, Card: [CARD REDACTED], Phone: [PHONE REDACTED]."
    }
  },
  {
    "instruction": "Generate a draft quotation. Then finalize it by changing the customer name, updating the sentence ending, and confirming the amount through multiple amend operations.",
    "dsl_program": "Customer Alice will pay about 100 dollars tomorrow.\n[CODE]amend $STATEMENT: Alice -> Bob\n[CODE]amend $STATEMENT: about 100 dollars -> 120 dollars\n[CODE]amend $STATEMENT: tomorrow. -> as agreed.",
    "output_json": {
      "__STATEMENT__": "Customer Bob will pay 120 dollars as agreed."
    }
  },

  // APP-11: 複雑な数式計算結果に基づくdictキーの動的選択
  {
    "instruction": "Select the correct month name by first calculating a month index. Store all month abbreviations in a list, compute the index with an arithmetic expression, verify the selected month with show, and report the result.",
    "dsl_program": "[CODE]$months = list str \"Jan\", str \"Feb\", str \"Mar\", str \"Apr\", str \"May\", str \"Jun\", str \"Jul\", str \"Aug\", str \"Sep\", str \"Oct\", str \"Nov\", str \"Dec\"\n[CODE]$index = int 2 + 3\n[CODE]show $months.$index\n[RESULT]Jun\nThe selected month is $months.$index.",
    "output_json": {
      "months": [
        "Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"
      ],
      "index": 5,
      "__STATEMENT__": "The selected month is Jun."
    }
  },
  {
    "instruction": "Determine the weekday by computing the remainder of a division. Store the weekday names in a list, calculate the index, verify the selected value with show, and describe the day.",
    "dsl_program": "[CODE]$weekdays = list str \"Sun\", str \"Mon\", str \"Tue\", str \"Wed\", str \"Thu\", str \"Fri\", str \"Sat\"\n[CODE]$index = int 10 % 7\n[CODE]show $weekdays.$index\n[RESULT]Wed\nToday corresponds to $weekdays.$index.",
    "output_json": {
      "weekdays": [
        "Sun","Mon","Tue","Wed","Thu","Fri","Sat"
      ],
      "index": 3,
      "__STATEMENT__": "Today corresponds to Wed."
    }
  },
  {
    "instruction": "Calculate a dice result, use it to choose a message from a list, confirm the selected message with show, and then generate a sentence describing the outcome.",
    "dsl_program": "[CODE]$messages = list str \"Try again\", str \"Good\", str \"Excellent\", str \"Lucky\", str \"Amazing\", str \"Perfect\"\n[CODE]$roll = int 2 * 3\n[CODE]$index = int $roll - 1\n[CODE]show $messages.$index\n[RESULT]Perfect\nThe dice rolled $roll. Message: $messages.$index.",
    "output_json": {
      "roll": 6,
      "index": 5,
      "__STATEMENT__": "The dice rolled 6. Message: Perfect."
    }
  },
  {
    "instruction": "Compute a user's rank level, retrieve the corresponding benefit from a dictionary, verify it with show, and summarize the reward.",
    "dsl_program": "[CODE]$benefits = dict 0:str \"Bronze\", 1:str \"Silver\", 2:str \"Gold\", 3:str \"Platinum\"\n[CODE]$rank = int 1 + 1\n[CODE]show $benefits.$rank\n[RESULT]Gold\nThe user receives the $benefits.$rank benefit.",
    "output_json": {
      "benefits": {
        "0": "Bronze",
        "1": "Silver",
        "2": "Gold",
        "3": "Platinum"
      },
      "rank": 2,
      "__STATEMENT__": "The user receives the Gold benefit."
    }
  },
  {
    "instruction": "Evaluate an HTTP status code, retrieve the corresponding description from a dictionary, verify the selected value with show, and produce a status report.",
    "dsl_program": "[CODE]$status = dict 200:str \"OK\", 404:str \"Not Found\", 500:str \"Internal Server Error\"\n[CODE]$code = int 404\n[CODE]show $status.$code\n[RESULT]Not Found\nStatus $code: $status.$code.",
    "output_json": {
      "status": {
        "200": "OK",
        "404": "Not Found",
        "500": "Internal Server Error"
      },
      "code": 404,
      "__STATEMENT__": "Status 404: Not Found."
    }
  },

