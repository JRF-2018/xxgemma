  // APP-06: dictや出力JSONからの要素の削除 (del文)
  {
    "instruction": "Create a user profile dictionary containing the fields name, password, and role. Remove the password field using del, verify the remaining dictionary with show, and generate a summary sentence.",
    "dsl_program": "[CODE]$profile = dict name:str \"Alice\", password:str \"secret123\", role:str \"admin\"\n[CODE]del password from $profile\n[CODE]show $profile\n[RESULT]{\"name\":\"Alice\",\"role\":\"admin\"}\nUser profile: $profile.name ($profile.role).",
    "output_json": {
      "profile": {
        "name": "Alice",
        "role": "admin"
      },
      "__STATEMENT__": "User profile: Alice (admin)."
    }
  },
  {
    "instruction": "Generate a report containing an internal status code. Remove the internal_code field from the final output object using del before producing the result.",
    "dsl_program": "[CODE]$title = str \"Daily Report\"\n[CODE]$internal_code = int 2001\nReport: $title.\n[CODE]del internal_code",
    "output_json": {
      "title": "Daily Report",
      "__STATEMENT__": "Report: Daily Report."
    }
  },
  {
    "instruction": "Create a debug report with a temporary debug flag. Remove the debug_flag field from the final output using del after confirming its value.",
    "dsl_program": "[CODE]$task = str \"Image Processing\"\n[CODE]$debug_flag = bool true\n[CODE]show $debug_flag\n[RESULT]true\nTask: $task completed.\n[CODE]del debug_flag",
    "output_json": {
      "task": "Image Processing",
      "__STATEMENT__": "Task: Image Processing completed."
    }
  },
  {
    "instruction": "Create a product dictionary containing the fields name, price, and discount_rate. Remove the discount_rate field using del because the product is no longer discounted, then describe the product.",
    "dsl_program": "[CODE]$product = dict name:str \"Laptop\", price:int 1200, discount_rate:int 20\n[CODE]del discount_rate from $product\n[CODE]show $product\n[RESULT]{\"name\":\"Laptop\",\"price\":1200}\n$product.name costs $product.price dollars.",
    "output_json": {
      "product": {
        "name": "Laptop",
        "price": 1200
      },
      "__STATEMENT__": "Laptop costs 1200 dollars."
    }
  },
  {
    "instruction": "Create a log entry containing user, action, and ip_address. Remove the ip_address field using del before producing the final output to protect privacy.",
    "dsl_program": "[CODE]$log = dict user:str \"Bob\", action:str \"login\", ip_address:str \"192.168.0.10\"\n[CODE]del ip_address from $log\n[CODE]show $log\n[RESULT]{\"user\":\"Bob\",\"action\":\"login\"}\nUser $log.user performed $log.action.",
    "output_json": {
      "log": {
        "user": "Bob",
        "action": "login"
      },
      "__STATEMENT__": "User Bob performed login."
    }
  },

  // APP-07: nestedなデータ構造（dict内のlist、list内のdict）の操作
  {
    "instruction": "Create a shopping cart represented as a dictionary containing a list of product dictionaries. Access the name and price of the first item using nested field access, verify them with show, and generate a summary sentence.",
    "dsl_program": "[CODE]$cart = dict customer:str \"Alice\", items:list dict name:str \"Apple\", price:int 120, dict name:str \"Orange\", price:int 180\n[CODE]show $cart.items.0.name\n[RESULT]Apple\n[CODE]show $cart.items.0.price\n[RESULT]120\nThe first item in the cart is $cart.items.0.name, which costs $cart.items.0.price yen.",
    "output_json": {
      "cart": {
        "customer": "Alice",
        "items": [
          {
            "name": "Apple",
            "price": 120
          },
          {
            "name": "Orange",
            "price": 180
          }
        ]
      },
      "__STATEMENT__": "The first item in the cart is Apple, which costs 120 yen."
    }
  },
  {
    "instruction": "Create a company structure represented as a dictionary containing a list of employee dictionaries. Access the first employee's name using nested access, verify it with show, and describe the department.",
    "dsl_program": "[CODE]$company = dict department:str \"Engineering\", employees:list dict name:str \"Bob\", role:str \"Developer\", dict name:str \"Carol\", role:str \"Tester\"\n[CODE]show $company.employees.0.name\n[RESULT]Bob\n[CODE]show $company.department\n[RESULT]Engineering\nThe first employee in the $company.department department is $company.employees.0.name.",
    "output_json": {
      "company": {
        "department": "Engineering",
        "employees": [
          {
            "name": "Bob",
            "role": "Developer"
          },
          {
            "name": "Carol",
            "role": "Tester"
          }
        ]
      },
      "__STATEMENT__": "The first employee in the Engineering department is Bob."
    }
  },
  {
    "instruction": "Create a sensor record represented as a dictionary containing a list of measurements. Access the second measurement using nested indexing, verify it with show, and generate a report.",
    "dsl_program": "[CODE]$sensor = dict device:str \"Sensor-A\", history:list float 21.5, float 22.3, float 22.8\n[CODE]show $sensor.history.1\n[RESULT]22.3\nDevice $sensor.device recorded $sensor.history.1 degrees in the second measurement.",
    "output_json": {
      "sensor": {
        "device": "Sensor-A",
        "history": [
          21.5,
          22.3,
          22.8
        ]
      },
      "__STATEMENT__": "Device Sensor-A recorded 22.3 degrees in the second measurement."
    }
  },
  {
    "instruction": "Create movie information represented as a dictionary containing a list of cast members. Access the second actor using nested indexing, verify it with show, and generate a sentence.",
    "dsl_program": "[CODE]$movie = dict title:str \"Future World\", cast:list str \"Alice\", str \"David\", str \"Emma\"\n[CODE]show $movie.cast.1\n[RESULT]David\nThe second cast member of \"$movie.title\" is $movie.cast.1.",
    "output_json": {
      "movie": {
        "title": "Future World",
        "cast": [
          "Alice",
          "David",
          "Emma"
        ]
      },
      "__STATEMENT__": "The second cast member of \"Future World\" is David."
    }
  },
  {
    "instruction": "Create a blog article represented as a dictionary containing a list of tags and a list of comment dictionaries. Access the first commenter's name using nested field access, verify it with show, and summarize the article.",
    "dsl_program": "[CODE]$blog = dict title:str \"DSL Tutorial\", tags:list str \"AI\", str \"DSL\", comments:list dict user:str \"Tom\", message:str \"Great article!\", dict user:str \"Jane\", message:str \"Very helpful.\"\n[CODE]show $blog.comments.0.user\n[RESULT]Tom\n[CODE]show $blog.tags.1\n[RESULT]DSL\nThe article \"$blog.title\" has the tag $blog.tags.1 and the first comment was written by $blog.comments.0.user.",
    "output_json": {
      "blog": {
        "title": "DSL Tutorial",
        "tags": [
          "AI",
          "DSL"
        ],
        "comments": [
          {
            "user": "Tom",
            "message": "Great article!"
          },
          {
            "user": "Jane",
            "message": "Very helpful."
          }
        ]
      },
      "__STATEMENT__": "The article \"DSL Tutorial\" has the tag DSL and the first comment was written by Tom."
    }
  },

