  // APP-09: リスト末尾への追加操作のシミュレーション（amend/dict併用）
  {
    "instruction": "Create a shopping list and then simulate adding a new fruit to the end of the list. Use amend to update the list variable and report the final list.",
    "dsl_program": "[CODE]$shopping = list str \"Apple\", str \"Banana\"\n[CODE]amend $shopping: Banana -> Banana, Cherry\n[CODE]show $shopping\n[RESULT][\"Apple\", \"Banana\", \"Cherry\"]\nThe shopping list contains $shopping.0, $shopping.1, and $shopping.2.",
    "output_json": {
      "shopping": [
        "Apple",
        "Banana",
        "Cherry"
      ],
      "__STATEMENT__": "The shopping list contains Apple, Banana, and Cherry."
    }
  },
  {
    "instruction": "Create an alert history and simulate appending a new log entry to the end of the history. Update the variable using amend and describe the latest alert.",
    "dsl_program": "[CODE]$alerts = list str \"INFO: Started\", str \"WARNING: High memory\"\n[CODE]amend $alerts: WARNING: High memory -> WARNING: High memory, ERROR: Disk full\n[CODE]show $alerts.2\n[RESULT]ERROR: Disk full\nThe latest alert is $alerts.2.",
    "output_json": {
      "alerts": [
        "INFO: Started",
        "WARNING: High memory",
        "ERROR: Disk full"
      ],
      "__STATEMENT__": "The latest alert is ERROR: Disk full."
    }
  },
  {
    "instruction": "Create a CC recipient list and simulate adding another recipient. Update the list using amend and report all recipients.",
    "dsl_program": "[CODE]$cc = list str \"alice@example.com\", str \"bob@example.com\"\n[CODE]amend $cc: bob@example.com -> bob@example.com, carol@example.com\n[CODE]show $cc\n[RESULT][\"alice@example.com\", \"bob@example.com\", \"carol@example.com\"]\nThe CC recipients are $cc.0, $cc.1, and $cc.2.",
    "output_json": {
      "cc": [
        "alice@example.com",
        "bob@example.com",
        "carol@example.com"
      ],
      "__STATEMENT__": "The CC recipients are alice@example.com, bob@example.com, and carol@example.com."
    }
  },
  {
    "instruction": "Create a game inventory and simulate obtaining a new weapon. Update the inventory using amend and report the newly added weapon.",
    "dsl_program": "[CODE]$inventory = list str \"Potion\", str \"Shield\"\n[CODE]amend $inventory: Shield -> Shield, Sword\n[CODE]show $inventory.2\n[RESULT]Sword\nThe player obtained a new weapon: $inventory.2.",
    "output_json": {
      "inventory": [
        "Potion",
        "Shield",
        "Sword"
      ],
      "__STATEMENT__": "The player obtained a new weapon: Sword."
    }
  },
